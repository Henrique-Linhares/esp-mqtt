    {
        "id": "dl_trigger_fix",
        "type": "ui_template",
        "z": "33c2487104eb35db",
        "group": "group_monitor",
        "name": "JS Download Fixo",
        "order": 6,
        "width": "",
        "height": "",
        "format": "<script>\n(function(scope) {\n    scope.$watch('msg', function(msg) {\n        if (msg && msg.payload && msg.payload.length > 0) {\n            var head = \"Temperatura,Umidade,Data,Hora\\n\";\n            var blob = new Blob([head + msg.payload], {type: 'text/csv'});\n            var a = document.createElement('a');\n            a.href = window.URL.createObjectURL(blob);\n            a.download = 'sensores_historico.csv';\n            a.click();\n            scope.send({payload: \"\"});\n        }\n    });\n})(scope);\n</script>",
        "storeOutMessages": false,
        "fwdInMessages": true,
        "resendOnRefresh": false,
        "templateScope": "local",
        "className": "",
