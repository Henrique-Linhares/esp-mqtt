    {
        "id": "fn_csv_line",
        "type": "function",
        "z": "33c2487104eb35db",
        "name": "Formatar CSV",
        "func": "var t = msg.payload[\"ads/iniot/temperatura\"];\nvar u = msg.payload[\"ads/iniot/umidade\"];\nvar agora = new Date();\nvar d = agora.toLocaleDateString('pt-BR');\nvar h = agora.toLocaleTimeString('pt-BR');\n\nmsg.payload = t + \",\" + u + \",\" + d + \",\" + h + \"\\n\";\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
