    {
        "id": "3c34b23b2d43e093",
        "type": "function",
        "z": "6078a909eddd1d81",
        "name": "Formatar CSV",
        "func": "var t = msg.payload.temperatura;\nvar u = msg.payload.umidade;\n\nvar zulu = new Date().toISOString().replace(/\\.\\d{3}/, '');\n\nmsg.payload = t + \",\" + u + \",\" + zulu + \"\\n\";\nreturn msg;",
