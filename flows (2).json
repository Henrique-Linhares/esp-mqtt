    {
        "id": "5febc4d0a338cb21",
        "type": "function",
        "z": "6078a909eddd1d81",
        "name": "Parse & Join",
        "func": "var t = msg.payload.temperatura;\nvar u = msg.payload.umidade;\n\nif (t === undefined || u === undefined) {\n    node.warn(\"Payload inválido: \" + JSON.stringify(msg.payload));\n    return null;\n}\n\nreturn [\n    [{ payload: t, topic: \"temperatura\" }],\n    [{ payload: u, topic: \"umidade\" }],\n    [{ payload: { temperatura: t, umidade: u } }]\n];",
        "outputs": 3,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
