    {
        "id": "1431165c9c78d4d8",
        "type": "ui_template",
        "z": "6078a909eddd1d81",
        "group": "group_monitor",
        "name": "JS Download Fixo",
        "order": 6,
        "width": "",
        "height": "",
        "format": "<script>\n(function(scope) {\n    scope.$watch('msg', function(msg) {\n        if (msg && msg.payload && msg.payload.length > 0) {\n            var head = \"Temperatura,Umidade,Timestamp\\n\";\n            var blob = new Blob([head + msg.payload], {type: 'text/csv'});\n            var a = document.createElement('a');\n            a.href = window.URL.createObjectURL(blob);\n            a.download = 'dados.csv';\n            a.click();\n            scope.send({payload: \"\"});\n        }\n    });\n})(scope);\n</script>",
        "storeOutMessages": false,
        "fwdInMessages": true,
        "resendOnRefresh": false,
        "templateScope": "local",
